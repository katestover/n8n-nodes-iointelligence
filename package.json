{
  "name": "n8n-nodes-iointelligence",
  "version": "0.1.0",
  "description": "n8n community node for IO Intelligence — use io.net's inference API as an AI model provider in n8n workflows",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ai",
    "llm",
    "io-intelligence",
    "io-net",
    "inference"
  ],
  "license": "MIT",
  "homepage": "https://github.com/katestover/n8n-nodes-iointelligence#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/katestover/n8n-nodes-iointelligence.git"
  },
  "bugs": {
    "url": "https://github.com/katestover/n8n-nodes-iointelligence/issues"
  },
  "author": {
    "name": "katestover"
  },
  "main": "index.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/IoIntelligenceApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/LmChatIoIntelligence/LmChatIoIntelligence.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "build:noicons": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepublishOnly": "npm run build:noicons"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "@langchain/openai": ">=0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.5.0",
    "gulp": "^5.0.0"
  }
}
